# Fly.io config for the Reaching Unreal sync server.
# Replace `app` with your own name (it must be globally unique on Fly).

app = "reaching-unreal-sync"
primary_region = "sjc"

[build]

[env]
  PORT = "1234"
  DATA_DIR = "/data"

[[mounts]]
  source = "ru_data"
  destination = "/data"

[http_service]
  internal_port = 1234
  force_https = true
  auto_stop_machines = false
  auto_start_machines = true
  min_machines_running = 1

[[vm]]
  cpu_kind = "shared"
  cpus = 1
  memory_mb = 256
