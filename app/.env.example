# Copy to .env.local for local dev, or set in your hosting provider
# (Vercel/Netlify) for production builds.

# Yjs websocket sync server. Required for cross-device sync.
# Local dev (after `npm start` in ../server):
VITE_YWS_URL=ws://localhost:1234
# Production (after deploying ../server to Fly):
# VITE_YWS_URL=wss://reaching-unreal-sync.fly.dev

# Optional: change the room name (everyone connecting to the same room shares
# the same workspace). Default: reaching-unreal-default.
# VITE_ROOM=elshazly-and-elsayed
